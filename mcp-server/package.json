{
  "name": "@loraloop/mcp-server",
  "version": "1.1.0",
  "description": "MCP server for Loraloop - connect your AI marketing platform to Claude",
  "type": "module",
  "bin": {
    "loraloop-mcp": "./build/mcp/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x build/mcp/index.js build/plugin/http.js",
    "dev": "tsx src/mcp/index.ts",
    "dev:plugin": "tsx src/plugin/http.ts",
    "start": "node build/mcp/index.js",
    "start:plugin": "node build/plugin/http.js",
    "clean": "rm -rf build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.0",
    "express": "^4.22.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
