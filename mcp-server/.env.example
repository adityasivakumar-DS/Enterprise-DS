# Loraloop API Configuration
LORALOOP_API_URL=http://localhost:3000
LORALOOP_API_KEY=

# Authentication (choose one method)
# Method 1: Email + Password login
LORALOOP_EMAIL=
LORALOOP_PASSWORD=

# Method 2: Direct JWT token (from Loraloop dashboard → Settings → API Keys)
LORALOOP_JWT_TOKEN=

# Optional: Default workspace/project context
LORALOOP_WORKSPACE_ID=
LORALOOP_PROJECT_ID=
